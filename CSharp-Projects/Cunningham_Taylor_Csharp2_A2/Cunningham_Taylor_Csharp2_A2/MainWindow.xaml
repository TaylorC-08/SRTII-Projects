<Window x:Class="Cunningham_Taylor_Csharp2_A2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Cunningham_Taylor_Csharp2_A2"
        mc:Ignorable="d"
        Title="Z-Score Calculator" Height="400" Width="400">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="10" />
            <ColumnDefinition Width="60" />
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="10"/>
            <RowDefinition Height="auto" />
            <RowDefinition Height="10" />
            <RowDefinition Height="100" />
            <RowDefinition Height="10" />
            <RowDefinition Height="230" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Column="1" Grid.Row="1" Text="Data: "/>

        <TextBox x:Name="txtdata" Grid.Column="2" Grid.Row="1" />

        <Button Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="3" x:Name="calculate" Click="calculateClick" Margin="2">
            <Image Source="/ButtonPicture.png"></Image>
        </Button>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="5" >
            <TextBlock x:Name="txtScrolling" TextWrapping="Wrap" Text=""/>
        </ScrollViewer>
    </Grid>
</Window>